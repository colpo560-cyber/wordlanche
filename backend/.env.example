# The private key of the resolver wallet
RESOLVER_PRIVATE_KEY=your_private_key_here

# Server secret for word randomization
SERVER_SECRET=your_server_secret_here

# Server port (optional, defaults to 3001)
PORT=3001

# Node environment (development or production)
NODE_ENV=development

# Avalanche Fuji RPC URL (optional, defaults to public endpoint)
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# WordleRoyaleFree contract address on Avalanche Fuji
CONTRACT_ADDRESS=0xEaA8E77E6C53fec28D60EEb64533a001b8F413b1

# Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=https://your-app.amplifyapp.com
